rules_version = '2';

// Storage voor operations + EventSheet SaaS.
service firebase.storage {
  match /b/{bucket}/o {

    // QR-PDF's: publiek leesbaar (PDF wordt rechtstreeks gedownload door
    // wie de QR scant), maar schrijven/verwijderen vereist auth. Alle pagina's
    // die naar deze map schrijven gebruiken anonymous Firebase Auth.
    match /qr-pdfs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.role != 'bakker'
                   && (request.resource == null
                       || (request.resource.size < 25 * 1024 * 1024
                           && request.resource.contentType == 'application/pdf'));
    }

    // Operations — archief. Bulk-geüploade PDF's en later via Operations
    // gegenereerde lijsten. Intern: lezen én schrijven vereist auth.
    match /archief/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.resource == null
                       || request.resource.size < 50 * 1024 * 1024);
    }

    // EventSheet — taakbijlagen. Auth-required: organisators via Firebase Auth,
    // leveranciers via custom-token in een aparte portal Firebase-app.
    match /tasks/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.resource == null
                       || request.resource.size < 25 * 1024 * 1024);
    }

    // EventSheet — aanvraagbijlagen. Zelfde auth-vereiste.
    match /requests/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.resource == null
                       || request.resource.size < 25 * 1024 * 1024);
    }

    // Alles wat hierbuiten valt: dicht.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
