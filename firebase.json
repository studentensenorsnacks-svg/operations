{
  "hosting": [
    {
      "target": "ops",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        ".git/**",
        ".firebase/**",
        ".github/**",
        "**/node_modules/**",
        "functions/**",
        "functions-saas/**",
        "saas/**",
        "greendeal/**",
        "eventpay/**",
        "**/*.md",
        "*.json",
        "storage.rules",
        "firestore.rules"
      ],
      "redirects": [
        {
          "source": "/event-sheet.html",
          "destination": "https://eventsheet-app.web.app/app",
          "type": 301
        }
      ],
      "rewrites": [
        {
          "source": "/api/anthropic",
          "function": {
            "functionId": "anthropicProxy",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/poets",
          "function": {
            "functionId": "poetsApi",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/vet-tonnen",
          "function": {
            "functionId": "vetTonnenApi",
            "region": "europe-west1"
          }
        },
        {
          "source": "/poets-extern",
          "destination": "/poets-extern.html"
        },
        {
          "source": "/poetsen",
          "destination": "/poets-extern.html"
        },
        {
          "source": "/vet-extern",
          "destination": "/vet-tonnen-extern.html"
        },
        {
          "source": "/vetstatus",
          "destination": "/vet-tonnen-extern.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "ops-login",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        ".git/**",
        ".firebase/**",
        ".github/**",
        "**/node_modules/**",
        "functions/**",
        "functions-saas/**",
        "saas/**",
        "greendeal/**",
        "eventpay/**",
        "**/*.md",
        "*.json",
        "storage.rules",
        "firestore.rules"
      ],
      "redirects": [
        {
          "source": "/event-sheet.html",
          "destination": "https://eventsheet-app.web.app/app",
          "type": 301
        }
      ],
      "rewrites": [
        {
          "source": "/api/anthropic",
          "function": {
            "functionId": "anthropicProxy",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/poets",
          "function": {
            "functionId": "poetsApi",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/vet-tonnen",
          "function": {
            "functionId": "vetTonnenApi",
            "region": "europe-west1"
          }
        },
        {
          "source": "/poets-extern",
          "destination": "/poets-extern.html"
        },
        {
          "source": "/poetsen",
          "destination": "/poets-extern.html"
        },
        {
          "source": "/vet-extern",
          "destination": "/vet-tonnen-extern.html"
        },
        {
          "source": "/vetstatus",
          "destination": "/vet-tonnen-extern.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "greendeal",
      "public": "greendeal",
      "ignore": [],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "source": "eventpay",
      "target": "eventpay",
      "frameworksBackend": {
        "region": "europe-west1",
        "memory": "512MiB",
        "minInstances": 0,
        "maxInstances": 3,
        "concurrency": 80,
        "secrets": ["EVENTPAY_API_KEY", "EVENTPAY_ADMIN_EMAIL", "EVENTPAY_ADMIN_PASSWORD", "AUTH_USERNAME", "AUTH_PASSWORD"]
      }
    },
    {
      "target": "saas",
      "public": "saas",
      "ignore": [],
      "rewrites": [
        { "source": "/app", "destination": "/eventsheet.html" },
        { "source": "/app/**", "destination": "/eventsheet.html" },
        { "source": "/login", "destination": "/eventsheet.html" },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        }
      ]
    }
  ],
  "functions": [
    { "source": "functions", "codebase": "default" },
    { "source": "functions-saas", "codebase": "saas" }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "firestore": {
    "rules": "firestore.rules",
    "database": "event"
  },
  "database": {
    "rules": "database.rules.json"
  }
}
