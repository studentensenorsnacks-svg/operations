          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "lommel",
      "public": "lommel-sk-offerte",
      "ignore": ["firebase.json", "**/.*"],
      "rewrites": [
        {
          "source": "**",
          "function": { "functionId": "lommelOffer", "region": "europe-west1" }
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-store" }
          ]
        }
      ]
    },
    {
      "target": "offertes",
      "public": "offertes-public",
      "ignore": ["firebase.json", "**/.*"],
      "rewrites": [
        {
          "source": "**",
          "function": { "functionId": "offerteRouter", "region": "europe-west1" }
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-store" }
          ]
        }
      ]
    },
    {
      "target": "info",
      "public": "info",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "https://senorsnacks.be",
          "type": 301
        }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "source": "eventpay",
      "target": "eventpay",
      "frameworksBackend": {
        "region": "europe-west1",
        "memory": "512MiB",
        "minInstances": 0,
        "maxInstances": 3,
        "concurrency": 80,
        "secrets": ["EVENTPAY_API_KEY", "EVENTPAY_ADMIN_EMAIL", "EVENTPAY_ADMIN_PASSWORD", "AUTH_USERNAME", "AUTH_PASSWORD"]
      }
    },
    {
      "target": "saas",
      "public": "saas",
      "ignore": [],
      "rewrites": [
        { "source": "/app", "destination": "/eventsheet.html" },
        { "source": "/app/**", "destination": "/eventsheet.html" },
        { "source": "/login", "destination": "/eventsheet.html" },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        }
      ]
    }
  ],
  "functions": [
    { "source": "functions", "codebase": "default" },
    { "source": "functions-saas", "codebase": "saas" }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "firestore": {
    "rules": "firestore.rules",
    "database": "event"
  },
  "database": {
    "rules": "database.rules.json"
  }
}
