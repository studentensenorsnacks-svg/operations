{
  "hosting": [
    {
      "target": "ops",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        ".git/**",
        ".firebase/**",
        ".github/**",
        "**/node_modules/**",
        "functions/**",
        "functions-saas/**",
        "saas/**",
        "greendeal/**",
        "eventpay/**",
        "**/*.md",
        "*.json",
        "storage.rules",
        "firestore.rules"
      ],
      "redirects": [
        {
          "source": "/trucks/:rest*",
          "destination": "https://senorkeuringqr.web.app/trucks/:rest*",
          "type": 301
        },
        {
          "source": "/event-sheet.html",
          "destination": "https://eventsheet-app.web.app/app",
          "type": 301
        }
      ],
      "rewrites": [
        {
          "source": "/api/anthropic",
          "function": {
            "functionId": "anthropicProxy",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/mistral",
          "function": {
            "functionId": "mistralProxy",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/poets",
          "function": {
            "functionId": "poetsApi",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/keuring",
          "function": {
            "functionId": "keuringPdfProxy",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/vet-tonnen",
          "function": {
            "functionId": "vetTonnenApi",
            "region": "europe-west1"
          }
        },
        {
          "source": "/poets-extern",
          "destination": "/poets-extern.html"
        },
        {
          "source": "/poetsen",
          "destination": "/poets-extern.html"
        },
        {
          "source": "/vet-extern",
          "destination": "/vet-tonnen-extern.html"
        },
        {
          "source": "/vetstatus",
          "destination": "/vet-tonnen-extern.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        },
        {
          "source": "/@(auth|ai-chat).js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "ops-login",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
