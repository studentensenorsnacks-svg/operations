{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      ".git/**",
      ".firebase/**",
      ".github/**",
      "**/node_modules/**",
      "functions/**",
      "**/*.md",
      "*.json"
    ],
    "rewrites": [
      {
        "source": "/api/refresh-outlook",
        "function": {
          "functionId": "refreshOutlook",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
