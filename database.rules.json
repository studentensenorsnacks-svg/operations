{
  "rules": {
    ".read": false,
    ".write": false,

    "ft_planning_v1":              { ".read": "auth != null", ".write": "auth != null" },
    "ft_planning_outlook_archief": { ".read": "auth != null", ".write": "auth != null" },

    "ft_planning_backup": {
      ".read": "auth != null",
      "$ts": {
        ".write": "auth != null && (!data.exists() || !newData.exists())"
      }
    },

    "ft_ops_v1":          { ".read": "auth != null", ".write": "auth != null" },
    "ft_ops_v2":          { ".read": "auth != null", ".write": "auth != null" },
    "ft_priority_v1":     { ".read": "auth != null", ".write": "auth != null" },
    "ft_laadlijst_v1":    { ".read": "auth != null", ".write": "auth != null" },
    "ft_laadlijsten_v1":  { ".read": "auth != null", ".write": "auth != null" },
    "ft_horeca_laadlijst_v1": { ".read": "auth != null", ".write": "auth != null" },
    "ft_eindstock_v1":    { ".read": "auth != null", ".write": "auth != null" },
    "ft_fiches_v1":       { ".read": "auth != null", ".write": "auth != null" },
    "ft_notities_v1":     { ".read": "auth != null", ".write": "auth != null" },
    "ft_qrcodes_meta_v1": { ".read": "auth != null", ".write": "auth != null" },
    "ft_qrcodes_v1":      { ".read": "auth != null", ".write": "auth != null" },
    "ft_stroomaanvraag_v1": { ".read": "auth != null", ".write": "auth != null" },
    "ft_bestellingen_v1":     { ".read": "auth != null", ".write": "auth != null" },
    "ft_bestel_catalogus_v1": { ".read": "auth != null", ".write": "auth != null" },
    "ft_trucks_v1":       { ".read": "auth != null", ".write": "auth != null" },
    "ft_poets_history":   { ".read": "auth != null", ".write": "auth != null" },
    "foldtable_requests": { ".read": "auth != null", ".write": "auth != null" },
    "ocb_keuringen":      { ".read": "auth != null", ".write": "auth != null" },
    "vet_tonnen":         { ".read": "auth != null", ".write": "auth != null" },

    "_userActivity": {
      ".read": "auth != null && auth.token.role == 'admin'",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid && !auth.token.firebase.sign_in_provider.matches(/^anonymous$/i)",
        ".read":  "auth != null && (auth.uid == $uid || auth.token.role == 'admin')",
        "lastSeen":       { ".validate": "newData.isNumber()" },
        "lastLogin":      { ".validate": "newData.isNumber()" },
        "loginCount":     { ".validate": "newData.isNumber()" },
        "email":          { ".validate": "newData.isString() && newData.val().length < 200" },
        "displayName":    { ".validate": "newData.isString() && newData.val().length < 200" },
        "provider":       { ".validate": "newData.isString() && newData.val().length < 40" },
        "userAgent":      { ".validate": "newData.isString() && newData.val().length < 400" },
        "loginHistory": {
          "$ts": {
            ".validate": "newData.hasChildren()",
            "provider":  { ".validate": "newData.isString() && newData.val().length < 40" },
            "userAgent": { ".validate": "newData.isString() && newData.val().length < 400" },
            "$other":    { ".validate": false }
          }
        },
        "$other": { ".validate": false }
      }
    }
  }
}
