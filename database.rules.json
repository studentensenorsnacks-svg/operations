    "ft_personeel_v1": {
      ".read":  "auth != null && !auth.token.firebase.sign_in_provider.matches(/^anonymous$/i) && auth.token.role != 'bakker' && (auth.token.role != 'custom' || (auth.token.pages != null && auth.token.pages.contains('|personeel|')))",
      "$id": {
        ".write": "auth != null && ((!data.exists() && newData.exists() && newData.child('bron').val() == 'aanmelding') || (!auth.token.firebase.sign_in_provider.matches(/^anonymous$/i) && auth.token.role != 'bakker' && (auth.token.role != 'custom' || (auth.token.pages != null && auth.token.pages.contains('|personeel|')))))",
        ".validate": "newData.hasChildren(['naamVoornaam','email'])",
        "naamVoornaam":     { ".validate": "newData.isString() && newData.val().length < 200" },
        "email":            { ".validate": "newData.isString() && newData.val().length < 200" },
        "adres":            { ".validate": "newData.isString() && newData.val().length < 300" },
        "gsm":              { ".validate": "newData.isString() && newData.val().length < 60" },
        "statuut":          { ".validate": "newData.isString() && newData.val().length < 40" },
        "gezinssituatie":   { ".validate": "newData.isString() && newData.val().length < 60" },
        "kinderenTenLaste": { ".validate": "newData.isString() && newData.val().length < 20" },
        "partnerTenLaste":  { ".validate": "newData.isString() && newData.val().length < 10" },
        "rijksregister":    { ".validate": "newData.isString() && newData.val().length < 40" },
        "identiteitskaart": { ".validate": "newData.isString() && newData.val().length < 60" },
        "iban":             { ".validate": "newData.isString() && newData.val().length < 60" },
        "nationaliteit":    { ".validate": "newData.isString() && newData.val().length < 60" },
        "akkoord":          { ".validate": "newData.isBoolean()" },
        "status":           { ".validate": "newData.isString() && newData.val().length < 20" },
        "bron":             { ".validate": "newData.isString() && newData.val().length < 20" },
        "opmerkingen":      { ".validate": "newData.isString() && newData.val().length < 4000" },
        "submittedAt":      { ".validate": "newData.isNumber()" },
        "$other":           { ".validate": false }
      }
    },

    "_userActivity": {
      ".read": "auth != null && auth.token.role == 'admin'",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid && !auth.token.firebase.sign_in_provider.matches(/^anonymous$/i)",
        ".read":  "auth != null && (auth.uid == $uid || auth.token.role == 'admin')",
        "lastSeen":       { ".validate": "newData.isNumber()" },
        "lastLogin":      { ".validate": "newData.isNumber()" },
        "lastLogout":     { ".validate": "newData.isNumber()" },
        "loginCount":     { ".validate": "newData.isNumber()" },
        "email":          { ".validate": "newData.isString() && newData.val().length < 200" },
        "displayName":    { ".validate": "newData.isString() && newData.val().length < 200" },
        "provider":       { ".validate": "newData.isString() && newData.val().length < 40" },
        "userAgent":      { ".validate": "newData.isString() && newData.val().length < 400" },
        "loginHistory": {
          "$ts": {
            ".validate": "newData.hasChildren()",
            "type":      { ".validate": "newData.isString() && newData.val().length < 20" },
            "provider":  { ".validate": "newData.isString() && newData.val().length < 40" },
            "userAgent": { ".validate": "newData.isString() && newData.val().length < 400" },
            "$other":    { ".validate": false }
          }
        },
        "$other": { ".validate": false }
      }
    },

    "_deletions": {
      ".read": "auth != null && auth.token.role == 'admin'",
      "$id": {
        ".write": "auth != null && !auth.token.firebase.sign_in_provider.matches(/^anonymous$/i) && (!data.exists() || auth.token.role == 'admin')",
        ".validate": "newData.hasChildren()",
        "type":   { ".validate": "newData.isString() && newData.val().length < 60" },
        "label":  { ".validate": "newData.isString() && newData.val().length < 300" },
        "ref":    { ".validate": "newData.isString() && newData.val().length < 200" },
        "detail": { ".validate": "newData.isString() && newData.val().length < 4000" },
        "at":     { ".validate": "newData.isNumber()" },
        "uid":    { ".validate": "newData.isString() && newData.val().length < 200" },
        "email":  { ".validate": "newData.isString() && newData.val().length < 200" },
        "name":   { ".validate": "newData.isString() && newData.val().length < 200" },
        "page":   { ".validate": "newData.isString() && newData.val().length < 200" },
        "$other": { ".validate": false }
      }
    },

    "_bestelLog": {
      ".read": "auth != null && auth.token.role == 'admin'",
      "$id": {
        ".write": "auth != null && !auth.token.firebase.sign_in_provider.matches(/^anonymous$/i) && (!data.exists() || auth.token.role == 'admin')",
        ".validate": "newData.hasChildren()",
        "action": { ".validate": "newData.isString() && newData.val().length < 80" },
        "detail": { ".validate": "newData.isString() && newData.val().length < 600" },
        "at":     { ".validate": "newData.isNumber()" },
        "uid":    { ".validate": "newData.isString() && newData.val().length < 200" },
        "email":  { ".validate": "newData.isString() && newData.val().length < 200" },
        "name":   { ".validate": "newData.isString() && newData.val().length < 200" },
        "page":   { ".validate": "newData.isString() && newData.val().length < 200" },
        "$other": { ".validate": false }
      }
    },

    "_aiLogs": {
      ".read": "auth != null && auth.token.role == 'admin'",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid && !auth.token.firebase.sign_in_provider.matches(/^anonymous$/i)",
        ".read":  "auth != null && (auth.uid == $uid || auth.token.role == 'admin')",
        "$conv": {
          "meta": {
            "uid":         { ".validate": "newData.isString() && newData.val().length < 200" },
            "email":       { ".validate": "newData.isString() && newData.val().length < 200" },
            "displayName": { ".validate": "newData.isString() && newData.val().length < 200" },
            "role":        { ".validate": "newData.isString() && newData.val().length < 40" },
            "startedAt":   { ".validate": "newData.isNumber()" },
            "updatedAt":   { ".validate": "newData.isNumber()" },
            "firstPage":   { ".validate": "newData.isString() && newData.val().length < 200" },
            "$other":      { ".validate": false }
          },
          "events": {
            "$eid": {
              ".validate": "newData.hasChildren()",
              "t":        { ".validate": "newData.isNumber()" },
              "kind":     { ".validate": "newData.isString() && newData.val().length < 20" },
              "model":    { ".validate": "newData.isString() && newData.val().length < 40" },
              "agent":    { ".validate": "newData.isBoolean()" },
              "page":     { ".validate": "newData.isString() && newData.val().length < 200" },
              "text":     { ".validate": "newData.isString() && newData.val().length < 8000" },
              "tool":     { ".validate": "newData.isString() && newData.val().length < 40" },
              "target":   { ".validate": "newData.isString() && newData.val().length < 400" },
              "value":    { ".validate": "newData.isString() && newData.val().length < 600" },
              "approved": { ".validate": "newData.isBoolean()" },
              "$other":   { ".validate": false }
            }
          },
          "$other": { ".validate": false }
        }
      }
    }
