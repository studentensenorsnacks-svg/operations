# EventPay API configuratie
# Kopieer dit bestand naar .env.local en vul de echte waarden in.
# .env.local komt niet in git terecht (zie .gitignore).

# Basis-URL van de EventPay API voor dit event.
# Bijvoorbeeld: https://senor-snacks.eventpay.be
EVENTPAY_BASE_URL=https://senor-snacks.eventpay.be

# Bearer token (API-key) van EventPay.
# Vraag dit op bij EventPay. Roteer deze key direct als hij ooit per ongeluk
# in een chat, log, screenshot of git-commit terechtkomt.
EVENTPAY_API_KEY=zet-hier-je-key

# ─── Admin login (alleen nodig voor de event-koppeling pagina) ─────────────
# De publieke API kan de sector van een apparaat NIET wijzigen.
# Daarom logt onze backend voor die specifieke actie in op de EventPay
# admin-website met jouw persoonlijke credentials, zodat we via de
# ingelogde sessie kunnen schrijven. Dit is een omweg, geen officiële API.
#
# LET OP:
#  - Behandel dit wachtwoord als een wachtwoord. Niet in chat, e-mail, screenshots of git.
#  - .env.local zit in .gitignore en wordt nooit gecommit.
#  - Wijzig je je wachtwoord op EventPay? Update het hier ook.
EVENTPAY_ADMIN_EMAIL=jouw@email.be
EVENTPAY_ADMIN_PASSWORD=jouw-wachtwoord

# ─── Login / rollen voor DEZE beheer-app ───────────────────────────────────
# De app zelf is afgeschermd met een loginpagina. Twee rollen:
#   • admin (centrale beheerder): mag alles, inclusief beheerders aanmaken.
#   • beheerder: mag alles behalve accountbeheer. Wordt door de admin
#     aangemaakt via /beheerders en opgeslagen in Firestore (database "event",
#     collectie "eventpay_beheerders").
#
# De centrale admin valt standaard terug op senorphbss / 123654789phbss.
# Overschrijf dat in productie met onderstaande variabelen (zet ze als secret).
ADMIN_USERNAME=senorphbss
ADMIN_PASSWORD=123654789phbss

# Geheime sleutel waarmee de sessie-cookie wordt ondertekend. Zet dit in
# productie op een lange, willekeurige waarde. Niet gezet → afgeleid van
# ADMIN_PASSWORD (werkt, maar minder veilig).
SESSION_SECRET=zet-hier-een-lange-willekeurige-string
